@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies
find_dependency(PandoraSDK REQUIRED)
find_dependency(LCContent REQUIRED)

# Include the targets file
include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")

# Define legacy variables - ONLY for this package's own headers
set(@PROJECT_NAME@_INCLUDE_DIR "@CMAKE_INSTALL_PREFIX@/include")
set(@PROJECT_NAME@_INCLUDE_DIRS "${@PROJECT_NAME@_INCLUDE_DIR}")
set(@PROJECT_NAME@_LIBRARIES "@CMAKE_INSTALL_PREFIX@/lib64/libPfoMonitoring.so")


# Get all linked libraries (including transitive)
#get_target_property(@PROJECT_NAME@_LIBRARIES PandoraPFA::@PROJECT_NAME@ INTERFACE_LINK_LIBRARIES)

check_required_components(@PROJECT_NAME@)
